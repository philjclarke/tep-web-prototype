---
import Base from '../layouts/Base.astro';
---
<Base title="Search results — The Education People" active="" header={true} footer={true}>

<style is:global>
/* ---------- Search Results (page-specific) ---------- */
  .results-hero { background: linear-gradient(135deg, var(--pink-soft) 0%, var(--lavender-soft) 45%, var(--cyan-soft) 100%); padding: 40px 0 44px; }
  .results-hero h1 { font-size: 30px; color: var(--purple); }
  .results-hero h1 span { color: var(--ink); }

  /* ---------- Filter results — matches the live Training & Events listing
     pattern exactly: pill dropdowns w/ Reset Filter lists, Dates -> inline
     start/end + calendar popover, Filters -> row of 3 further dropdowns,
     popular tags, Applied Filters panel. ---------- */
  .filter-area { padding: 30px 0 4px; }
  .filter-area [hidden] { display: none !important; }
  .fr-title { font-size: 22px; color: var(--ink); margin-bottom: 16px; }
  .filter-bar { display: flex; gap: 12px; align-items: stretch; flex-wrap: wrap; }
  .fb-search { flex: 1 1 300px; max-width: 420px; background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 4px 4px 4px 20px; display: flex; align-items: center; gap: 10px; }
  .fb-search input { flex: 1; min-width: 0; border: 0; outline: 0; font-family: var(--sans); font-size: 15px; color: var(--ink); background: transparent; }
  .fb-search button { width: 42px; height: 42px; background: var(--purple); color: #fff; border: 0; border-radius: 50%; display: grid; place-items: center; font-size: 15px; cursor: pointer; flex-shrink: 0; }
  .fb-dd-wrap { position: relative; }
  .fb-dd { height: 100%; display: inline-flex; align-items: center; gap: 9px; background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 12px 20px; font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--purple); cursor: pointer; transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease; }
  .filter-bar > .fb-dd { height: auto; }
  .fb-dd:hover { border-color: var(--purple); }
  .fb-dd i.lead { font-size: 13px; }
  .fb-dd .caret { font-size: 11px; transition: transform 0.2s ease; }
  .fb-dd.open { background: var(--purple); border-color: var(--purple); color: #fff; }
  .fb-dd.open .caret { transform: rotate(180deg); }
  .fb-panel { position: absolute; top: calc(100% + 6px); left: 0; z-index: 60; background: #fff; border-radius: 0 0 14px 14px; box-shadow: 0 24px 60px rgba(26,18,38,0.22); min-width: 100%; width: max-content; max-width: 320px; max-height: 340px; overflow-y: auto; padding-bottom: 6px; }
  .fb-panel .reset-row { display: flex; align-items: center; gap: 9px; width: 100%; text-align: left; background: #fff; border: 0; border-bottom: 1px solid var(--line); padding: 14px 18px; font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--purple); cursor: pointer; }
  .fb-panel .opt { display: block; width: 100%; text-align: left; background: #fff; border: 0; padding: 12px 18px; font-family: var(--sans); font-size: 14px; color: var(--ink); cursor: pointer; }
  .fb-panel .opt:hover { background: var(--paper); }
  .fb-panel .opt.selected { color: var(--purple); font-weight: 700; }
  .fb-panel .opt.selected::after { content: "\2713"; margin-left: 8px; }

  /* expansion rows (Dates / Filters) */
  .fx-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 12px; position: relative; }
  .fx-label { font-size: 14px; font-weight: 700; color: var(--ink); }
  .date-pill { background: #fff; border: 1px solid var(--purple); border-radius: 999px; padding: 10px 20px; font-family: var(--sans); font-size: 14px; font-weight: 500; color: var(--ink); cursor: pointer; }
  .date-pill:hover { background: var(--lavender-soft); }
  .fx-filters .fb-dd-wrap { flex: 1 1 240px; }
  .fx-filters .fb-dd { width: 100%; justify-content: space-between; }

  /* calendar popover */
  .cal-pop { position: absolute; top: calc(100% + 10px); left: 0; z-index: 70; background: #fff; border-radius: 18px; box-shadow: 0 28px 70px rgba(26,18,38,0.25); padding: 18px 20px 20px; width: 560px; max-width: 92vw; }
  .cal-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .cal-today { background: var(--lavender-soft); border: 1px solid var(--line); border-radius: 999px; padding: 7px 16px; font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--ink); cursor: pointer; }
  .cal-top .right { display: flex; align-items: center; gap: 12px; }
  .cal-clear { background: none; border: 0; font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--ink); text-decoration: underline; cursor: pointer; }
  .cal-x { width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--line); background: #fff; color: var(--ink); font-size: 11px; cursor: pointer; display: grid; place-items: center; }
  .cal-months { display: grid; grid-template-columns: 1fr 1fr; gap: 26px; position: relative; }
  .cal-nav { position: absolute; top: 4px; background: none; border: 0; color: var(--charcoal); font-size: 14px; cursor: pointer; padding: 4px 8px; }
  .cal-nav.prev { left: -6px; }
  .cal-nav.next { right: -6px; }
  .cal-m h6 { text-align: center; font-size: 16px; font-weight: 700; color: var(--purple); margin-bottom: 10px; font-family: var(--sans); }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
  .cal-grid .dow { text-align: center; font-size: 12px; font-weight: 700; color: var(--purple); padding: 4px 0; }
  .cal-grid .day { text-align: center; font-size: 13px; color: var(--ink); padding: 7px 0; border-radius: 8px; cursor: pointer; background: none; border: 0; font-family: var(--sans); }
  .cal-grid .day:hover { background: var(--lavender-soft); }
  .cal-grid .day.sel { background: var(--purple); color: #fff; font-weight: 700; }
  .cal-grid .blank { pointer-events: none; }

  .popular-tags { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
  .popular-tags .lbl { font-size: 14px; font-weight: 700; color: var(--ink); }
  .ptag { cursor: pointer; font-family: var(--sans); }
  .ptag.active { background: var(--purple); border-color: var(--purple); color: #fff; }

  /* applied filters */
  .applied { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 16px 20px; margin-top: 18px; }
  .ap-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .ap-head span { font-size: 14px; font-weight: 700; color: var(--purple); }
  .ap-clear { background: none; border: 0; font-family: var(--sans); font-size: 13px; font-weight: 600; color: var(--purple); cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
  .ap-clear:hover { text-decoration: underline; }
  .ap-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 6px; }
  .ap-group:last-child { margin-bottom: 0; }
  .ap-k { font-size: 13px; font-weight: 600; color: var(--purple); }
  .ap-chip { display: inline-flex; align-items: center; gap: 8px; background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 6px 8px 6px 14px; font-size: 13px; font-weight: 500; color: var(--ink); }
  .ap-chip button { border: 0; background: none; color: var(--ink); cursor: pointer; font-size: 11px; padding: 0 4px; }
  .ap-chip button:hover { color: var(--purple); }

  .results-wrap { padding: 26px 0 90px; }

  /* results column */
  .results-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; gap: 16px; flex-wrap: wrap; }
  .results-count { font-size: 15px; color: var(--charcoal); }
  .results-count strong { color: var(--ink); }
  .sort { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--charcoal); }
  .sort select { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--ink); border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; background: #fff; cursor: pointer; }


  .results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  /* card CTA row */
  .card .card-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; }
  .card .card-foot .cta { font-weight: 600; font-size: 14px; color: var(--purple); display: inline-flex; align-items: center; gap: 7px; }
  .card .card-foot .cta i { transition: transform 0.2s ease; }
  .card:hover .card-foot .cta i { transform: translateX(3px); }
  .card .card-price { font-weight: 700; color: var(--ink); font-size: 14px; }

  .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 44px; }
  .pagination a { min-width: 40px; height: 40px; padding: 0 12px; border-radius: 10px; border: 1px solid var(--line); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; color: var(--ink); }
  .pagination a:hover { border-color: var(--lavender); color: var(--purple); }
  .pagination a.active { background: var(--purple); color: #fff; border-color: var(--purple); }
  .pagination a.arrow { color: var(--purple); }

  /* related content recommendations */
  .discover-more { border-top: 1px solid var(--line); padding: 56px 0 64px; }
  .discover-more .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

  /* related searches */
  .related-searches { background: var(--paper); border-top: 1px solid var(--line); padding: 48px 0; }
  .related-searches h3 { font-size: 18px; color: var(--ink); margin-bottom: 16px; }
  .related-searches .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .related-searches .chips a { background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 9px 18px; font-size: 14px; font-weight: 500; color: var(--purple); }
  .related-searches .chips a:hover { border-color: var(--purple); }
</style>

<!-- ================= RESULTS HERO ================= -->
<section class="results-hero">
  <div class="container">
    <h1>Results for <span>“Safeguarding”</span></h1>
  </div>
</section>

<div class="container">
  <!-- FILTER RESULTS — matches the live Training & Events listing pattern -->
  <div class="filter-area">
    <h3 class="fr-title">Filter results</h3>
    <div class="filter-bar">
      <form class="fb-search" onsubmit="return false">
        <input value="Safeguarding" aria-label="Search">
        <button type="submit" aria-label="Search"><i class="fa-solid fa-magnifying-glass"></i></button>
      </form>

      <div class="fb-dd-wrap" data-facet="Content Type">
        <button class="fb-dd" type="button">Content Type <i class="fa-solid fa-chevron-down caret"></i></button>
        <div class="fb-panel" hidden>
          <button class="reset-row" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Filter</button>
        <button class="opt selected" type="button">Training & Events</button>
        <button class="opt" type="button">Products & Resources</button>
        <button class="opt" type="button">Services</button>
        <button class="opt" type="button">Blogs</button>
        <button class="opt" type="button">Knowledge Hub</button>
        </div>
      </div>

      <div class="fb-dd-wrap" data-facet="Delivery Method">
        <button class="fb-dd" type="button">Delivery Method <i class="fa-solid fa-chevron-down caret"></i></button>
        <div class="fb-panel" hidden>
          <button class="reset-row" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Filter</button>
        <button class="opt" type="button">Conferences & Events</button>
        <button class="opt" type="button">E-Learning</button>
        <button class="opt" type="button">Face to face Training</button>
        <button class="opt selected" type="button">Live Online Training</button>
        <button class="opt" type="button">Recorded Webinar</button>
        </div>
      </div>

      <button class="fb-dd" type="button" id="dates-toggle"><i class="fa-regular fa-calendar lead"></i> Dates <i class="fa-solid fa-chevron-down caret"></i></button>
      <button class="fb-dd" type="button" id="filters-toggle"><i class="fa-solid fa-filter lead"></i> Filters <i class="fa-solid fa-chevron-down caret"></i></button>
    </div>

    <!-- Dates expansion: start/end pills + calendar popover -->
    <div class="fx-row" id="dates-row" hidden>
      <span class="fx-label">Start:</span>
      <button class="date-pill" type="button" data-target="start">Select start date</button>
      <span class="fx-label">End:</span>
      <button class="date-pill" type="button" data-target="end">Select end date</button>
      <div class="cal-pop" id="cal-pop" hidden>
        <div class="cal-top">
          <button class="cal-today" type="button">Today</button>
          <div class="right">
            <button class="cal-clear" type="button">Clear</button>
            <button class="cal-x" type="button" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
          </div>
        </div>
        <div class="cal-months">
          <button class="cal-nav prev" type="button" aria-label="Previous month"><i class="fa-solid fa-chevron-left"></i></button>
          <button class="cal-nav next" type="button" aria-label="Next month"><i class="fa-solid fa-chevron-right"></i></button>
          <div class="cal-m" id="cal-m0"></div>
          <div class="cal-m" id="cal-m1"></div>
        </div>
      </div>
    </div>

    <!-- Filters expansion: three further dropdowns -->
    <div class="fx-row fx-filters" id="filters-row" hidden>
      <div class="fb-dd-wrap" data-facet="Customer Type">
        <button class="fb-dd" type="button">Customer Type <i class="fa-solid fa-chevron-down caret"></i></button>
        <div class="fb-panel" hidden>
          <button class="reset-row" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Filter</button>
        <button class="opt" type="button">Academy & MAT</button>
        <button class="opt" type="button">Business</button>
        <button class="opt" type="button">College & Higher Education</button>
        <button class="opt" type="button">Council / Local Authority</button>
        <button class="opt" type="button">Early Years & Childcare</button>
        <button class="opt" type="button">Foster Carer & Supported Homes</button>
        <button class="opt" type="button">International School</button>
        <button class="opt" type="button">Other</button>
        </div>
      </div>
      <div class="fb-dd-wrap" data-facet="Audience">
        <button class="fb-dd" type="button">Audience <i class="fa-solid fa-chevron-down caret"></i></button>
        <div class="fb-panel" hidden>
          <button class="reset-row" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Filter</button>
        <button class="opt" type="button">Administration & Finance</button>
        <button class="opt" type="button">All Teaching Staff</button>
        <button class="opt" type="button">Careers Leads</button>
        <button class="opt" type="button">Childminder</button>
        <button class="opt" type="button">Designated Safeguarding Leads</button>
        <button class="opt" type="button">Governors</button>
        <button class="opt" type="button">Head Teacher</button>
        <button class="opt" type="button">School support staff</button>
        </div>
      </div>
      <div class="fb-dd-wrap" data-facet="Product Topic">
        <button class="fb-dd" type="button">Product Topic <i class="fa-solid fa-chevron-down caret"></i></button>
        <div class="fb-panel" hidden>
          <button class="reset-row" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Filter</button>
        <button class="opt" type="button">Anxiety</button>
        <button class="opt" type="button">Assessment</button>
        <button class="opt" type="button">Attendance</button>
        <button class="opt" type="button">Behaviour</button>
        <button class="opt" type="button">Curriculum</button>
        <button class="opt" type="button">Ofsted</button>
        <button class="opt" type="button">Safeguarding</button>
        <button class="opt" type="button">SEND</button>
        </div>
      </div>
    </div>

    <div class="popular-tags">
      <span class="lbl">Popular tags:</span>
      <button class="topic-tag ptag active" type="button">Safeguarding</button>
      <button class="topic-tag ptag" type="button">EYFS</button>
      <button class="topic-tag ptag" type="button">SEND</button>
      <button class="topic-tag ptag" type="button">Leadership &amp; Management</button>
      <button class="topic-tag ptag" type="button">Ofsted</button>
      <button class="topic-tag ptag" type="button">Attendance</button>
