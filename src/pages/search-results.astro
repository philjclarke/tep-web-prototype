<!-- ================= FOOTER (shared) ================= -->

<script is:inline>
// Filter results — mirrors the live T&E listing behaviour (mock, front-end only):
// dropdowns w/ Reset Filter lists, Dates/Filters expansion rows, two-month
// calendar popover, popular-tag toggles, grouped Applied Filters panel.
  (function() {
    const state = {};
    const facetOrder = ['Content Type', 'Delivery Method', 'Dates', 'Customer Type', 'Audience', 'Product Topic', 'Tags'];

    /* dropdown panels */
    const wraps = Array.from(document.querySelectorAll('.fb-dd-wrap'));
    const closePanels = () => wraps.forEach(w => { w.querySelector('.fb-dd').classList.remove('open'); w.querySelector('.fb-panel').hidden = true; });
    wraps.forEach(w => {
      const btn = w.querySelector('.fb-dd');
      const panel = w.querySelector('.fb-panel');
      const facet = w.dataset.facet;
      state[facet] = Array.from(panel.querySelectorAll('.opt.selected')).map(o => o.textContent.trim());
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = btn.classList.contains('open');
        closePanels(); calClose();
        if (!wasOpen) { btn.classList.add('open'); panel.hidden = false; }
      });
      panel.addEventListener('click', (e) => e.stopPropagation());
      panel.querySelectorAll('.opt').forEach(o => o.addEventListener('click', () => {
        o.classList.toggle('selected'); sync(facet, panel);
      }));
      panel.querySelector('.reset-row').addEventListener('click', () => {
        panel.querySelectorAll('.opt.selected').forEach(o => o.classList.remove('selected')); sync(facet, panel);
      });
    });
    const sync = (facet, panel) => { state[facet] = Array.from(panel.querySelectorAll('.opt.selected')).map(o => o.textContent.trim()); render(); };

    /* Dates / Filters expansion rows */
    const rowToggle = (btnId, rowId) => {
      const btn = document.getElementById(btnId), row = document.getElementById(rowId);
      btn.addEventListener('click', (e) => {
        e.stopPropagation(); closePanels(); calClose();
        const open = btn.classList.toggle('open');
        row.hidden = !open;
      });
    };
    rowToggle('dates-toggle', 'dates-row');
    rowToggle('filters-toggle', 'filters-row');

    /* popular tags */
    state['Tags'] = [];
    const ptags = Array.from(document.querySelectorAll('.ptag'));
    const syncTags = () => { state['Tags'] = ptags.filter(t => t.classList.contains('active')).map(t => t.textContent.trim()); render(); };
    ptags.forEach(t => t.addEventListener('click', () => { t.classList.toggle('active'); syncTags(); }));
    state['Tags'] = ptags.filter(t => t.classList.contains('active')).map(t => t.textContent.trim());

    /* calendar */
    const pop = document.getElementById('cal-pop');
    const pills = Array.from(document.querySelectorAll('.date-pill'));
    const dates = { start: null, end: null };
    let target = 'start';
    let mY = 2026, mM = 6; // July 2026 to match mock content
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const fmt = (d) => d.getDate() + ' ' + MONTHS[d.getMonth()].slice(0,3) + ' ' + d.getFullYear();
    const calClose = () => { pop.hidden = true; };
    const renderMonth = (el, y, m) => {
      const first = new Date(y, m, 1).getDay(); // Sunday-first like the live site
      const days = new Date(y, m + 1, 0).getDate();
      let html = '<h6>' + MONTHS[m] + ' ' + y + '</h6><div class="cal-grid">';
      'SMTWTFS'.split('').forEach(d => html += '<span class="dow">' + d + '</span>');
      for (let i = 0; i < first; i++) html += '<span class="day blank"></span>';
      for (let d = 1; d <= days; d++) {
        const sel = (dates.start && dates.start.getFullYear() === y && dates.start.getMonth() === m && dates.start.getDate() === d) ||
                    (dates.end && dates.end.getFullYear() === y && dates.end.getMonth() === m && dates.end.getDate() === d);
        html += '<button class="day' + (sel ? ' sel' : '') + '" data-d="' + d + '" data-m="' + m + '" data-y="' + y + '" type="button">' + d + '</button>';
      }
      el.innerHTML = html + '</div>';
      el.querySelectorAll('.day:not(.blank)').forEach(b => b.addEventListener('click', () => {
        pick(new Date(+b.dataset.y, +b.dataset.m, +b.dataset.d));
      }));
    };
    const renderCal = () => {
      const n = new Date(mY, mM + 1, 1);
      renderMonth(document.getElementById('cal-m0'), mY, mM);
      renderMonth(document.getElementById('cal-m1'), n.getFullYear(), n.getMonth());
    };
    const syncDates = () => {
      const vals = [];
      if (dates.start) vals.push('From ' + fmt(dates.start));
      if (dates.end) vals.push('To ' + fmt(dates.end));
      state['Dates'] = vals; render();
    };
    const pick = (d) => {
      dates[target] = d;
      pills.forEach(p => { if (p.dataset.target === target) p.textContent = fmt(d); });
      syncDates(); renderCal(); calClose();
    };
    const clearDates = () => {
      dates.start = dates.end = null;
      pills.forEach(p => { p.textContent = p.dataset.target === 'start' ? 'Select start date' : 'Select end date'; });
      syncDates(); renderCal();
    };
    pills.forEach(p => p.addEventListener('click', (e) => {
      e.stopPropagation(); closePanels();
      target = p.dataset.target;
      pop.hidden = false; renderCal();
    }));
    pop.addEventListener('click', (e) => e.stopPropagation());
    pop.querySelector('.cal-today').addEventListener('click', () => pick(new Date()));
    pop.querySelector('.cal-clear').addEventListener('click', clearDates);
    pop.querySelector('.cal-x').addEventListener('click', calClose);
    pop.querySelector('.cal-nav.prev').addEventListener('click', () => { mM--; if (mM < 0) { mM = 11; mY--; } renderCal(); });
    pop.querySelector('.cal-nav.next').addEventListener('click', () => { mM++; if (mM > 11) { mM = 0; mY++; } renderCal(); });

    /* applied filters panel */
    const panelEl = document.getElementById('applied-panel');
    const groupsEl = document.getElementById('ap-groups');
    function render() {
      const entries = facetOrder.filter(k => (state[k] || []).length);
      panelEl.hidden = !entries.length;
      groupsEl.innerHTML = entries.map(k =>
        '<div class="ap-group"><span class="ap-k">' + k + ':</span>' +
        state[k].map(v => '<span class="ap-chip">' + v + ' <button type="button" data-facet="' + k + '" data-val="' + v + '" aria-label="Remove">✕</button></span>').join('') +
        '</div>').join('');
      groupsEl.querySelectorAll('button').forEach(b => b.addEventListener('click', () => remove(b.dataset.facet, b.dataset.val)));
    }
    function remove(facet, val) {
      if (facet === 'Tags') {
        ptags.forEach(t => { if (t.textContent.trim() === val) t.classList.remove('active'); });
        syncTags();
      } else if (facet === 'Dates') {
        if (val.indexOf('From') === 0) { dates.start = null; } else { dates.end = null; }
        pills.forEach(p => {
          if (p.dataset.target === 'start' && !dates.start) p.textContent = 'Select start date';
          if (p.dataset.target === 'end' && !dates.end) p.textContent = 'Select end date';
        });
        syncDates(); renderCal();
      } else {
        const wrap = wraps.find(w => w.dataset.facet === facet);
        wrap.querySelectorAll('.opt.selected').forEach(o => { if (o.textContent.trim() === val) o.classList.remove('selected'); });
        sync(facet, wrap.querySelector('.fb-panel'));
      }
    }
    document.querySelector('.ap-clear').addEventListener('click', () => {
      wraps.forEach(w => { w.querySelectorAll('.opt.selected').forEach(o => o.classList.remove('selected')); state[w.dataset.facet] = []; });
      ptags.forEach(t => t.classList.remove('active')); state['Tags'] = [];
      dates.start = dates.end = null;
      pills.forEach(p => { p.textContent = p.dataset.target === 'start' ? 'Select start date' : 'Select end date'; });
      state['Dates'] = []; render(); renderCal();
    });

    document.addEventListener('click', () => { closePanels(); calClose(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closePanels(); calClose(); } });
    render();
  })();
</script>

</Base>
