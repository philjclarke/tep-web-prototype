---
import Base from '../layouts/Base.astro';
---
<Base title="Search results — The Education People" active="" header={true} footer={true}>

<style is:global>
/* ---------- Search Results (page-specific) ---------- */
  .results-hero { background: linear-gradient(135deg, var(--pink-soft) 0%, var(--lavender-soft) 45%, var(--cyan-soft) 100%); padding: 40px 0 44px; }
  .results-hero h1 { font-size: 30px; color: var(--purple); margin-bottom: 18px; }
  .results-hero h1 span { color: var(--ink); }
  .big-search { background: #fff; border-radius: 16px; padding: 8px 8px 8px 22px; display: flex; align-items: center; gap: 12px; max-width: 720px; box-shadow: 0 16px 40px rgba(65,0,140,0.12); }
  .big-search .ic { width: 20px; height: 20px; border-radius: 50%; border: 2.5px solid var(--purple); position: relative; flex-shrink: 0; }
  .big-search .ic::after { content: ""; position: absolute; width: 10px; height: 2.5px; background: var(--purple); bottom: -3px; right: -5px; transform: rotate(45deg); }
  .big-search input { flex: 1; border: 0; outline: 0; font-family: var(--sans); font-size: 16px; color: var(--ink); background: transparent; }
  .big-search button { background: var(--purple); color: #fff; border: 0; border-radius: 12px; padding: 14px 28px; font-family: var(--sans); font-weight: 600; font-size: 15px; cursor: pointer; }

  .results-layout { display: grid; grid-template-columns: 264px 1fr; gap: 40px; padding: 36px 0 90px; align-items: start; }

  /* filters rail */
  .filters { position: sticky; top: 20px; border: 1px solid var(--line); border-radius: 16px; padding: 8px 20px 20px; }
  .filters-head { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid var(--line); }
  .filters-head h3 { font-size: 16px; color: var(--ink); }
  .filters-head a { font-size: 13px; color: var(--purple); font-weight: 600; }
  .fgroup { border-bottom: 1px solid var(--line); padding: 16px 0; }
  .fgroup:last-child { border-bottom: 0; }
  .fgroup h4 { font-size: 14px; color: var(--ink); margin-bottom: 12px; }
  .fopt { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--charcoal); padding: 5px 0; cursor: pointer; }
  .fopt input { appearance: none; width: 18px; height: 18px; border: 2px solid var(--line); border-radius: 5px; flex-shrink: 0; position: relative; cursor: pointer; transition: background-color 0.15s, border-color 0.15s; }
  .fopt input:checked { background: var(--purple); border-color: var(--purple); }
  .fopt input:checked::after { content: "\2713"; position: absolute; inset: 0; color: #fff; font-size: 12px; display: grid; place-items: center; }
  .fopt .count { margin-left: auto; font-size: 12px; color: #9a96a6; }
  .fopt:hover { color: var(--purple); }

  /* results column */
  .results-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; gap: 16px; flex-wrap: wrap; }
  .results-count { font-size: 15px; color: var(--charcoal); }
  .results-count strong { color: var(--ink); }
  .sort { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--charcoal); }
  .sort select { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--ink); border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; background: #fff; cursor: pointer; }

  .active-filters { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-bottom: 22px; }
  .chip { display: inline-flex; align-items: center; gap: 8px; background: var(--lavender-soft); color: var(--purple); border-radius: 999px; padding: 6px 8px 6px 14px; font-size: 13px; font-weight: 600; }
  .chip button { border: 0; background: rgba(65,0,140,0.12); color: var(--purple); width: 18px; height: 18px; border-radius: 50%; cursor: pointer; font-size: 11px; display: grid; place-items: center; }
  .active-filters .clear { font-size: 13px; color: var(--charcoal); text-decoration: underline; margin-left: 4px; }

  .results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  /* card CTA row */
  .card .card-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; }
  .card .card-foot .cta { font-weight: 600; font-size: 14px; color: var(--purple); display: inline-flex; align-items: center; gap: 7px; }
  .card .card-foot .cta i { transition: transform 0.2s ease; }
  .card:hover .card-foot .cta i { transform: translateX(3px); }
  .card .card-price { font-weight: 700; color: var(--ink); font-size: 14px; }

  .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 44px; }
  .pagination a { min-width: 40px; height: 40px; padding: 0 12px; border-radius: 10px; border: 1px solid var(--line); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; color: var(--ink); }
  .pagination a:hover { border-color: var(--lavender); color: var(--purple); }
  .pagination a.active { background: var(--purple); color: #fff; border-color: var(--purple); }
  .pagination a.arrow { color: var(--purple); }

  /* related content recommendations */
  .discover-more { border-top: 1px solid var(--line); padding: 56px 0 64px; }
  .discover-more .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

  /* related searches */
  .related-searches { background: var(--paper); border-top: 1px solid var(--line); padding: 48px 0; }
  .related-searches h3 { font-size: 18px; color: var(--ink); margin-bottom: 16px; }
  .related-searches .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .related-searches .chips a { background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 9px 18px; font-size: 14px; font-weight: 500; color: var(--purple); }
  .related-searches .chips a:hover { border-color: var(--purple); }
</style>

<!-- ================= RESULTS HERO ================= -->
