      <div class="ap-head">
        <span>Applied Filters:</span>
        <button class="ap-clear" type="button"><i class="fa-solid fa-xmark"></i> Clear all</button>
      </div>
      <div id="ap-groups"></div>
    </div>
  </div>

  <div class="results-wrap">
    <div class="results-col">
      <div class="results-toolbar">
        <div class="results-count"><strong>48 results</strong> for “Safeguarding”</div>
