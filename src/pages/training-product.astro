  <div class="container">
    <div class="contact-card">
      <div>
        <h3>Need advice before you book?</h3>
        <p>Our team can help you find the right course or arrange bespoke training for your setting.</p>
      </div>
      <a href="#" class="btn-primary btn-lg">Contact us <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </div>
