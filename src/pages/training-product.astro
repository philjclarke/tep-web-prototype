---
import Base from '../layouts/Base.astro';
---
<Base title="Effective Coaching in Schools — The Education People" active="training" header={true} footer={true} marker="Template demo — typical density">

<style is:global>
/* ---------- Training Product Page (page-specific) ---------- */
  .product-wrap { padding: 26px 0 90px; }
  .product-head { max-width: 820px; margin-bottom: 28px; }
  .product-head .badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .product-head h1 { font-size: 44px; line-height: 1.05; color: var(--purple); margin-bottom: 14px; }
  .product-head .at-a-glance { font-size: 18px; color: var(--charcoal); line-height: 1.55; }

  .product-grid { display: grid; grid-template-columns: 1fr 372px; gap: 56px; align-items: start; }
  .product-main { min-width: 0; }

  /* hero image */
  .product-hero { position: relative; border-radius: 20px; overflow: hidden; height: 380px; margin-bottom: 32px; }
  .product-hero img { width: 100%; height: 100%; object-fit: cover; }
  .product-hero .badge { position: absolute; top: 18px; left: 18px; }

  /* quick facts strip */
  .facts { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 22px; background: var(--paper); border: 1px solid var(--line); border-radius: 16px; margin-bottom: 40px; }
  .facts .fact { display: flex; gap: 12px; align-items: flex-start; }
  .facts .fact .ic { width: 40px; height: 40px; border-radius: 10px; background: var(--lavender-soft); color: var(--purple); display: grid; place-items: center; font-size: 16px; flex-shrink: 0; }
  .facts .fact .k { font-size: 12px; color: var(--charcoal); text-transform: uppercase; letter-spacing: 0.05em; }
  .facts .fact .v { font-size: 15px; font-weight: 600; color: var(--ink); margin-top: 2px; }

  /* content sections */
  .section { margin-bottom: 44px; }
  .section > h2 { font-size: 26px; margin-bottom: 16px; }
  .section p { color: var(--charcoal); margin-bottom: 14px; line-height: 1.65; }
  .section .outcomes { list-style: none; display: grid; gap: 10px; margin-top: 6px; }
  .section .outcomes li { display: flex; gap: 12px; align-items: flex-start; color: var(--ink); }
  .section .outcomes li i { color: var(--purple); margin-top: 3px; }
  .included { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 28px; }
  .included .item { display: flex; gap: 12px; align-items: flex-start; }
  .included .item i { color: var(--purple); margin-top: 3px; }
  .included .item strong { display: block; color: var(--ink); font-weight: 600; }
  .included .item span { font-size: 14px; color: var(--charcoal); }

  /* trainer */
  .trainer { display: flex; gap: 22px; align-items: flex-start; background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 24px; }
  .trainer .expertise { display: flex; gap: 6px; flex-wrap: wrap; margin: 12px 0 14px; }
  .trainer .t-links { display: grid; gap: 6px; border-top: 1px solid var(--line); padding-top: 14px; margin-top: 2px; }
  .trainer .t-links .k { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--charcoal); }
  .trainer .t-links a { font-size: 14px; font-weight: 600; color: var(--purple); }
  .trainer .t-links a:hover { text-decoration: underline; }
  .trainer .t-links a i { font-size: 11px; margin-left: 5px; }
  .trainer .avatar { width: 92px; height: 92px; border-radius: 50%; background-size: cover; background-position: center; flex-shrink: 0; }
  .trainer .role { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--lavender); }
  .trainer h4 { font-size: 20px; color: var(--purple); margin: 2px 0 6px; }
  .trainer p { font-size: 14px; color: var(--charcoal); margin: 0; }

  /* FAQ */
  .faq { border: 1px solid var(--line); border-radius: 16px; overflow: hidden; }
  .faq details { border-bottom: 1px solid var(--line); }
  .faq details:last-child { border-bottom: 0; }
  .faq summary { list-style: none; cursor: pointer; padding: 18px 22px; font-weight: 600; font-size: 16px; color: var(--ink); display: flex; justify-content: space-between; align-items: center; gap: 16px; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary i { color: var(--purple); transition: transform 0.2s ease; flex-shrink: 0; }
  .faq details[open] summary i { transform: rotate(45deg); }
  .faq .faq-body { padding: 0 22px 20px; color: var(--charcoal); font-size: 15px; line-height: 1.6; }

  /* ---------- sticky booking panel ---------- */
  .booking { position: sticky; top: 20px; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; box-shadow: 0 20px 44px rgba(65,0,140,0.08); }
  .booking .price-row { padding: 24px; background: var(--paper); border-bottom: 1px solid var(--line); }
  .booking .price { font-size: 34px; font-weight: 800; color: var(--purple); letter-spacing: -0.02em; }
  .booking .price small { font-size: 15px; font-weight: 500; color: var(--charcoal); }
  .booking .package-note { font-size: 13px; color: var(--charcoal); margin-top: 6px; display: inline-flex; align-items: center; gap: 7px; }
  .booking .package-note .badge-sand { padding: 3px 9px; }
  .booking .panel-body { padding: 22px 24px 26px; }
  /* single event instance (per TEP business rules — one event per page) */
  .booking .dates-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--charcoal); margin-bottom: 10px; }
  .booking .event-box { border: 1px solid var(--purple); background: var(--lavender-soft); border-radius: 12px; padding: 14px 16px; display: flex; gap: 12px; align-items: flex-start; }
  .booking .event-box i { color: var(--purple); margin-top: 3px; }
  .booking .event-box .d { font-weight: 700; font-size: 15px; color: var(--ink); }
  .booking .event-box .loc { font-size: 13px; color: var(--charcoal); margin-top: 2px; }
  .booking .other-dates { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--purple); margin-top: 10px; }
  .booking .other-dates:hover { text-decoration: underline; }
  .booking .cta-stack { display: grid; gap: 10px; margin: 18px 0 16px; }
  .booking .mini-meta { display: grid; gap: 10px; padding-top: 16px; border-top: 1px solid var(--line); }
  .booking .mini-meta .line { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--charcoal); }
  .booking .mini-meta .line i { color: var(--purple); width: 16px; text-align: center; }
  .booking .advice { margin-top: 16px; font-size: 13px; color: var(--charcoal); }
  .booking .advice a { color: var(--purple); font-weight: 600; }

  /* related + contact (full width) */
  .related { background: var(--paper); border-top: 1px solid var(--line); padding: 64px 0; }
  .related .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .contact-band { padding: 56px 0; }
  .contact-card { background: var(--purple); color: #fff; border-radius: 20px; padding: 44px 48px; display: flex; justify-content: space-between; align-items: center; gap: 32px; position: relative; overflow: hidden; }
  .contact-card::before { content: ""; position: absolute; width: 280px; height: 280px; border-radius: 50%; background: var(--lavender); opacity: 0.25; right: -80px; top: -100px; }
  .contact-card > * { position: relative; z-index: 1; }
  .contact-card h3 { color: #fff; font-size: 26px; margin-bottom: 6px; }
  .contact-card p { color: #fff; opacity: 0.9; font-size: 15px; }
  .contact-card .btn-primary { background: #fff; color: var(--purple); border-color: #fff; }
  .contact-card .btn-primary:hover { background: var(--paper); border-color: var(--paper); }

  .breadcrumb-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; }
  .density-switch { font-size: 13px; font-weight: 600; color: var(--purple); border: 1px solid var(--line); border-radius: 999px; padding: 7px 14px; flex-shrink: 0; }
  .density-switch:hover { border-color: var(--purple); background: var(--lavender-soft); }
</style>

<!-- ================= PRODUCT ================= -->
<div class="container">
  <div class="breadcrumb-row">
    <div class="breadcrumb">
      <a href="/">Home</a><span class="sep">/</span>
      <a href="/search-results">Training &amp; Events</a><span class="sep">/</span>
      <span class="current">Effective Coaching in Schools</span>
    </div>
    <a class="density-switch" href="/training-product-rich"><i class="fa-solid fa-arrows-left-right"></i> Compare: content-rich version</a>
  </div>
</div>

<div class="product-wrap">
  <div class="container">

    <div class="product-head">
      <div class="badges">
        <span class="badge badge-purple">Training course</span>
        <span class="badge badge-light">CPD Accredited</span>
        <span class="badge badge-mint">Popular</span>
      </div>
      <h1>Effective Coaching in Schools</h1>
      <p class="at-a-glance">A practical, hands-on programme helping school leaders and teachers build a coaching culture that improves teaching, wellbeing and outcomes — with tools you can use straight away.</p>
    </div>

    <div class="product-grid">
      <!-- MAIN COLUMN -->
      <div class="product-main">

        <div class="product-hero">
          <span class="badge badge-light">Included in the Leadership Package</span>
          <img src="https://images.unsplash.com/photo-1544717305-2782549b5136?w=1100&q=80&auto=format&fit=crop" alt="Coaching session in a school">
        </div>

        <div class="facts">
          <div class="fact"><div class="ic"><i class="fa-regular fa-calendar"></i></div><div><div class="k">Next date</div><div class="v">15 Oct 2026</div></div></div>
          <div class="fact"><div class="ic"><i class="fa-regular fa-clock"></i></div><div><div class="k">Duration</div><div class="v">Full day</div></div></div>
          <div class="fact"><div class="ic"><i class="fa-solid fa-laptop"></i></div><div><div class="k">Delivery</div><div class="v">In-person</div></div></div>
          <div class="fact"><div class="ic"><i class="fa-solid fa-location-dot"></i></div><div><div class="k">Venue</div><div class="v">Ashford, Kent</div></div></div>
        </div>

        <div class="section">
          <h2>About this course</h2>
          <p>Coaching is one of the most powerful ways to develop staff, yet it's often squeezed out by the day-to-day. This course gives you a clear, practical framework for embedding coaching conversations into everyday school life — without adding to workload.</p>
          <p>Through worked examples, live practice and take-away tools, you'll leave able to hold better developmental conversations and to start building a genuine coaching culture across your setting.</p>
          <h2 style="font-size:20px;margin-top:26px;">What you'll learn</h2>
          <ul class="outcomes">
            <li><i class="fa-solid fa-circle-check"></i><span>A simple, repeatable model for coaching conversations that fit into a busy week.</span></li>
            <li><i class="fa-solid fa-circle-check"></i><span>How to ask questions that unlock thinking rather than give answers.</span></li>
            <li><i class="fa-solid fa-circle-check"></i><span>Ways to give feedback that motivates and develops, not just corrects.</span></li>
            <li><i class="fa-solid fa-circle-check"></i><span>Practical steps to build a sustainable coaching culture across your team.</span></li>
          </ul>
        </div>

        <div class="section">
          <h2>What's included</h2>
          <div class="included">
            <div class="item"><i class="fa-solid fa-user-tie"></i><div><strong>Expert-led full day</strong><span>Delivered by an experienced TEP leadership adviser.</span></div></div>
            <div class="item"><i class="fa-solid fa-folder-open"></i><div><strong>Resource pack</strong><span>Coaching frameworks, prompts and templates to reuse.</span></div></div>
            <div class="item"><i class="fa-solid fa-certificate"></i><div><strong>CPD certificate</strong><span>Certificated CPD hours for your record.</span></div></div>
            <div class="item"><i class="fa-solid fa-mug-hot"></i><div><strong>Refreshments &amp; lunch</strong><span>Included for all in-person attendees.</span></div></div>
          </div>
        </div>

        <div class="section">
          <h2>Meet your trainer</h2>
          <div class="trainer">
            <div class="avatar" style="background-image:url('https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=300&q=80&auto=format&fit=crop')"></div>
            <div>
              <div class="role">Leadership &amp; Coaching Adviser</div>
              <h4>Hannah Bloom</h4>
              <p>Former headteacher with 15 years' experience supporting schools with leadership development, coaching and school improvement across Kent and beyond.</p>
              <div class="expertise">
                <span class="topic-tag sm">Leadership</span>
                <span class="topic-tag sm">Coaching</span>
                <span class="topic-tag sm">School improvement</span>
                <span class="topic-tag sm">Appraisal</span>
              </div>
              <div class="t-links">
                <div><span class="k">Also delivers</span><br><a href="#">Middle Leadership Essentials<i class="fa-solid fa-arrow-right"></i></a> · <a href="#">Wellbeing for School Leaders<i class="fa-solid fa-arrow-right"></i></a></div>
                <div><span class="k">From the Knowledge Hub</span><br><a href="#">Making coaching stick: lessons from Kent schools<i class="fa-solid fa-arrow-right"></i></a></div>
              </div>
            </div>
          </div>
        </div>

        <div class="section">
          <h2>Frequently asked questions</h2>
          <div class="faq">
            <details open>
              <summary>Who is this course for? <i class="fa-solid fa-plus"></i></summary>
              <div class="faq-body">School leaders, middle leaders and teachers who line-manage or develop others. No prior coaching experience is needed.</div>
            </details>
            <details>
              <summary>Is this course accredited? <i class="fa-solid fa-plus"></i></summary>
              <div class="faq-body">Yes — attendees receive a certificate of CPD hours which can be used towards professional development records.</div>
            </details>
            <details>
              <summary>Can we book this for a whole team? <i class="fa-solid fa-plus"></i></summary>
              <div class="faq-body">Absolutely. We can deliver this course in-house for your setting — use the "Contact us" option below for group and bespoke pricing.</div>
            </details>
            <details>
              <summary>What if the date I want is full? <i class="fa-solid fa-plus"></i></summary>
              <div class="faq-body">You can join the waiting list and we'll let you know as soon as a place or a new date becomes available.</div>
            </details>
          </div>
        </div>

        <!-- topical tags (customer-facing tagging framework) + save/share -->
        <div class="topics-bar">
          <div class="topic-tags">
            <a class="topic-tag" href="/search-results">Leadership</a>
            <a class="topic-tag" href="/search-results">Coaching</a>
            <a class="topic-tag" href="/search-results">Staff development</a>
            <a class="topic-tag" href="/search-results">Wellbeing</a>
          </div>
          <div class="actions">
            <button aria-label="Save for later"><i class="fa-regular fa-bookmark"></i></button>
            <button aria-label="Share"><i class="fa-solid fa-share-nodes"></i></button>
          </div>
        </div>

      </div>

      <!-- BOOKING PANEL -->
      <aside class="booking">
        <div class="price-row">
          <div class="price">£195 <small>+ VAT per place</small></div>
          <div class="package-note"><span class="badge badge-sand">Package</span> Free if part of the Leadership Package</div>
        </div>
        <div class="panel-body">
          <div class="dates-label">Event details</div>
          <div class="event-box">
            <i class="fa-regular fa-calendar"></i>
            <div>
              <div class="d">15 October 2026</div>
              <div class="loc">9:15am–3:45pm · Ashford, Kent</div>
            </div>
          </div>
          <a class="other-dates" href="/search-results">View other dates for this course <i class="fa-solid fa-arrow-right"></i></a>

          <div class="cta-stack">
            <a href="#" class="btn-primary btn-block btn-lg">Book now <i class="fa-solid fa-arrow-right"></i></a>
            <a href="#" class="btn-ghost btn-block"><i class="fa-regular fa-heart"></i> Add to wishlist</a>
          </div>

          <div class="mini-meta">
            <div class="line"><i class="fa-solid fa-user-group"></i> 6 of 24 places remaining</div>
            <div class="line"><i class="fa-solid fa-laptop"></i> In-person, full day</div>
            <div class="line"><i class="fa-solid fa-location-dot"></i> Kent venues &amp; online options</div>
          </div>

          <p class="advice">Not sure if it's right for you? <a href="#">Contact us</a> before you book.</p>
        </div>
      </aside>
    </div>
  </div>
</div>

<!-- ================= RELATED TRAINING ================= -->
