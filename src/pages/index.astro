<script is:inline>
// Testimonial carousel — auto-rotates every 6s, pauses on hover; dots + arrows
  // for manual control (manual navigation restarts the timer).
  (function() {
    const card = document.querySelector('.trust-quote');
    if (!card) return;
    const slides = Array.from(card.querySelectorAll('.t-slide'));
    const dots = Array.from(card.querySelectorAll('.dot'));
    if (slides.length < 2) return;
    let i = 0, timer;
    const show = (n) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => s.classList.toggle('active', k === i));
      dots.forEach((d, k) => d.classList.toggle('active', k === i));
    };
    const start = () => { timer = setInterval(() => show(i + 1), 6000); };
    const restart = () => { clearInterval(timer); start(); };
    dots.forEach((d, k) => d.addEventListener('click', () => { show(k); restart(); }));
    card.querySelector('.t-prev').addEventListener('click', () => { show(i - 1); restart(); });
    card.querySelector('.t-next').addEventListener('click', () => { show(i + 1); restart(); });
    card.addEventListener('mouseenter', () => clearInterval(timer));
    card.addEventListener('mouseleave', start);
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) start();
  })();

  // Hero image parallax — each image moves at its own rate, slower than the page scroll.
  // Reversible because the transform is tied to absolute scrollY, so scrolling back unwinds it.
  (function() {
    const items = Array.from(document.querySelectorAll('.hero-img'));
    if (!items.length || matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      items.forEach(el => {
        const speed = parseFloat(el.dataset.speed) || 0.2;
        el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
      });
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  })();

  // Discover tabs — reorder the existing cards behind a quick fade so switching
  // tabs reads as fresh content loading in (mock; no new cards required).
  (function() {
    const tabs = Array.from(document.querySelectorAll('.tabs a'));
    const grid = document.querySelector('.courses');
    if (!tabs.length || !grid) return;
    const cards = Array.from(grid.children);
    // a visibly distinct arrangement per tab
    const orders = [
      [0, 1, 2, 3], // Training
      [2, 3, 1, 0], // Resources
      [3, 0, 2, 1], // Events
      [1, 2, 0, 3]  // Knowledge Hub
    ];
    grid.style.transition = 'opacity 0.2s ease';
    tabs.forEach((tab, i) => {
      tab.style.cursor = 'pointer';
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        if (tab.classList.contains('active')) return;
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        grid.style.opacity = '0';
        setTimeout(() => {
          (orders[i] || orders[0]).forEach(idx => grid.appendChild(cards[idx]));
          grid.style.opacity = '1';
        }, 200);
      });
    });
  })();

  // Animate stat numbers on scroll into view
  (function() {
    const easeOutCubic = t => 1 - Math.pow(1 - t, 3);
    const animateNum = (el) => {
      const original = el.textContent.trim();
      const match = original.match(/^([\d,]+)(.*)$/);
      if (!match) return;
      const target = parseInt(match[1].replace(/,/g, ''), 10);
      const suffix = match[2];
      const duration = 1600;
      const start = performance.now();
      const tick = (now) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = easeOutCubic(t);
        const v = Math.floor(target * eased);
        el.textContent = v.toLocaleString('en-GB') + suffix;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = original;
      };
      requestAnimationFrame(tick);
    };
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          animateNum(e.target);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    document.querySelectorAll('.trust-stat .num').forEach(el => io.observe(el));
  })();
</script>

