---
import Base from '../layouts/Base.astro';
---
<Base title="The Education People — Home" active="" header={true} footer={true}>

<style is:global>
/* ============================================================
     VARIANT D — BLEND
     - Hero: lighter ombre, CTA pair (no search), montage
     - Audience: 6 sector cards inc. Employment Support
     - Discover: combined featured tile + tabbed cards
     - Supported Employment: standalone bar
     - Stats + Testimonial: combined, light background
     - Why TEP / overview: retained
     ============================================================ */

  :root {
    --purple: #41008C;
    --purple-deep: #2C0061;
    --charcoal: #393E4B;
    --lavender: #9A6DD3;
    --lavender-soft: #EDE2FA;
    --cyan: #A6ECF4;
    --cyan-soft: #DAF8FB;
    --mint: #CCFFCC;
    --mint-soft: #E8FFE8;
    --pink: #F8D4FC;
    --pink-soft: #FCE7FD;
    --sand: #FCECAC;
    --sand-soft: #FEF6D6;
    --ink: #1A1226;
    --paper: #FAFAFC;
    --line: #E5E5EC;
    /* single neutral typeface for now — final type TBC with brand guidance */
    --serif: "Figtree", system-ui, -apple-system, sans-serif;
    --sans: "Figtree", system-ui, -apple-system, sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--sans);
    color: var(--ink);
    background: white;
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4 { font-family: var(--serif); font-weight: 700; letter-spacing: -0.015em; line-height: 1.05; color: var(--purple); }
  a { color: inherit; text-decoration: none; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 40px; }

  /* ============================================================
     TOP UTILITY + HEADER + MAIN NAV (carried over)
     ============================================================ */
  /* thin parent-company utility strip (kept minimal, not purple) */
  .util { background: var(--ink); color: white; font-size: 12px; padding: 8px 0; }
  .util .container { display: flex; justify-content: space-between; align-items: center; }
  .util .left { display: flex; align-items: center; gap: 9px; opacity: 0.85; }
  .util .dot { width: 15px; height: 15px; border-radius: 50%; background: white; }
  .util .right { font-weight: 600; letter-spacing: 0.08em; font-size: 11px; opacity: 0.85; }

  /* main header — light, spacious */
  .header { background: white; padding: 22px 0; }
  .header .container { display: flex; align-items: center; gap: 32px; }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo img { height: 50px; width: auto; display: block; }
  .search-box {
    flex: 0 1 460px; max-width: 460px;
    background: var(--paper); border: 1px solid var(--line); border-radius: 999px;
    padding: 12px 22px 12px 46px;
    position: relative; color: #8a869a; font-size: 14px;
    transition: border-color 0.2s ease;
  }
  .search-box:hover { border-color: var(--lavender); }
  .search-box::before {
    content: ""; position: absolute; left: 19px; top: 50%; transform: translateY(-50%);
    width: 15px; height: 15px; border-radius: 50%; border: 2px solid var(--purple);
  }
  .search-box::after {
    content: ""; position: absolute; left: 31px; top: 26px;
    width: 8px; height: 2px; background: var(--purple); transform: rotate(45deg);
  }
  .util-nav { display: flex; gap: 22px; align-items: center; font-size: 14px; margin-left: auto; }
  .util-nav > a { color: var(--ink); font-weight: 500; transition: color 0.15s ease; }
  .util-nav > a:hover { color: var(--purple); }
  .util-nav .basket { display: inline-flex; align-items: center; gap: 7px; }
  .util-nav .basket-icon { color: var(--ink); font-size: 16px; }
  .btn-login {
    background: var(--purple); color: white;
    padding: 11px 26px; border-radius: 999px;
    font-weight: 600; font-size: 14px;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .util-nav > a.btn-login, .util-nav > a.btn-login:hover { color: #fff; }
  .btn-login:hover { background: var(--purple-deep); transform: translateY(-1px); }

  /* primary nav — white, un-boxed, active underline, dropdowns */
  .mainnav { background: white; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); position: relative; z-index: 100; }
  .mainnav .container { display: flex; gap: 4px; }
  .nav-item { position: relative; }
  .nav-item > a {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 17px 18px; font-size: 15px; font-weight: 600; color: var(--ink);
    border-bottom: 3px solid transparent; margin-bottom: -1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .nav-item > a:hover { color: var(--purple); }
  .nav-item.active > a { color: var(--purple); border-bottom-color: var(--purple); }
  .nav-item .caret { font-size: 10px; opacity: 0.7; transition: transform 0.2s ease; }
  .nav-item:hover .caret, .nav-item:focus-within .caret { transform: rotate(180deg); }

  /* lightweight dropdown flyout (content-light by design) */
  .dropdown {
    position: absolute; top: 100%; left: 6px; min-width: 236px;
    background: white; border: 1px solid var(--line); border-radius: 16px;
    box-shadow: 0 22px 44px rgba(65,0,140,0.12);
    padding: 10px; margin-top: 6px;
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .nav-item:hover .dropdown, .nav-item:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown a { display: block; padding: 10px 14px; border-radius: 10px; font-size: 14px; font-weight: 500; color: var(--charcoal); transition: background-color 0.15s ease, color 0.15s ease; }
  .dropdown a:hover { background: var(--paper); color: var(--purple); }

  /* ============================================================
     HERO — lighter ombre, CTA pair, no search bar
     ============================================================ */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 52px 0 60px; /* compact per 16.07 feedback — was 100/120 */
    background: linear-gradient(135deg,
      var(--pink-soft) 0%,
      var(--pink) 22%,
      var(--lavender-soft) 45%,
      var(--cyan-soft) 65%,
      var(--cyan) 82%,
      var(--mint-soft) 100%
    );
  }
  .hero .container { position: relative; z-index: 5; display: grid; grid-template-columns: 1.05fr 1fr; gap: 60px; align-items: center; }
  .hero h1 {
    font-family: var(--sans);
    font-size: 64px;
    font-weight: 600;
    line-height: 1.0;
    margin-bottom: 20px;
    letter-spacing: -0.04em;
    color: var(--lavender);
  }
  .hero h1 em { font-style: normal; color: var(--purple); font-weight: 800; padding-right: 6px; }
  .hero .lead {
    font-size: 19px; line-height: 1.5;
    color: var(--charcoal);
    margin-bottom: 26px;
    max-width: 520px;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 24px; }
  .btn-primary {
    background: var(--purple); color: white;
    padding: 16px 32px; border-radius: 999px;
    font-weight: 600; font-size: 16px;
    display: inline-flex; align-items: center; gap: 10px;
    border: 2px solid var(--purple);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 14px 28px rgba(65,0,140,0.28); background: var(--purple-deep); border-color: var(--purple-deep); }
  .btn-primary::after { content: "→"; font-size: 18px; transition: transform 0.2s ease; }
  .btn-primary:hover::after { transform: translateX(4px); }
  .btn-ghost {
    background: transparent; color: var(--purple);
    border: 2px solid var(--purple);
    padding: 14px 28px; border-radius: 999px;
    font-weight: 600; font-size: 16px;
    display: inline-flex; align-items: center; gap: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }
  .btn-ghost:hover { transform: translateY(-3px); background: var(--purple); color: white; box-shadow: 0 14px 28px rgba(65,0,140,0.20); }
  .btn-ghost::after { content: "→"; font-size: 18px; transition: transform 0.2s ease; }
  .btn-ghost:hover::after { transform: translateX(4px); }
  .tags {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .tags-label { font-size: 14px; color: var(--charcoal); }
  .tag {
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(65,0,140,0.15);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px; color: var(--purple); font-weight: 500;
  }

  /* Hero — circular photo over slowly-drifting brand circles */
  .montage { position: relative; height: 430px; }

  /* drifting background circles (different colours / blends / opacities) */
  .hero-blob { position: absolute; border-radius: 50%; will-change: transform; }
  .hero-blob.b1 { width: 340px; height: 340px; background: var(--cyan);          top: -60px;    right: -60px;  opacity: 0.55; mix-blend-mode: multiply; animation: drift1 17s ease-in-out infinite; }
  .hero-blob.b2 { width: 250px; height: 250px; background: var(--mint);          top: 30px;     right: -130px; opacity: 0.70; mix-blend-mode: multiply; animation: drift2 21s ease-in-out infinite; }
  .hero-blob.b3 { width: 430px; height: 430px; background: var(--cyan);          bottom: -140px; left: -70px;  opacity: 0.45; mix-blend-mode: multiply; animation: drift3 23s ease-in-out infinite; }
  .hero-blob.b4 { width: 300px; height: 300px; background: var(--lavender-soft); bottom: -100px; right: -140px; opacity: 0.65; mix-blend-mode: multiply; animation: drift4 19s ease-in-out infinite; }
  .hero-blob.b5 { width: 170px; height: 170px; background: var(--pink);          top: 150px;    left: 0px;     opacity: 0.55; mix-blend-mode: multiply; animation: drift5 15s ease-in-out infinite; }

  @keyframes drift1 { 0%,100% { transform: translate(0,0); }     50% { transform: translate(18px, 14px); } }
  @keyframes drift2 { 0%,100% { transform: translate(0,0); }     50% { transform: translate(-22px, 18px); } }
  @keyframes drift3 { 0%,100% { transform: translate(0,0); }     50% { transform: translate(22px, -16px); } }
  @keyframes drift4 { 0%,100% { transform: translate(0,0); }     50% { transform: translate(-16px, -22px); } }
  @keyframes drift5 { 0%,100% { transform: translate(0,0); }     50% { transform: translate(14px, 22px); } }
  @media (prefers-reduced-motion: reduce) { .hero-blob { animation: none !important; } }

  /* circular hero photo (placeholder — to be replaced) */
  .hero-photo {
    position: absolute;
    width: 470px; height: 470px;
    top: 50%; right: -10px;
    transform: translateY(-50%);
    background: url("/hero-circle.png") center/contain no-repeat;
    z-index: 5;
  }

  /* ============================================================
     SECTION HELPERS
     ============================================================ */
  section.block { padding: 100px 0; }
  .eyebrow {
    font-family: var(--sans); font-weight: 600;
    font-size: 13px; letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lavender);
    margin-bottom: 5px;
  }
  .section-head { max-width: 720px; margin-bottom: 48px; }
  .section-head h2 { font-size: 52px; letter-spacing: -0.025em; }
  .section-head .lead { font-size: 18px; color: var(--charcoal); margin-top: 16px; line-height: 1.55; }
  .center { text-align: center; margin-left: auto; margin-right: auto; }

  /* ============================================================
     AUDIENCE — 6 sector cards inc. Employment Support
     ============================================================ */
  .audience { background: white; }
  .audience .container { max-width: 1360px; }

  /* expanding image accordion — equal at rest, focus-driven expansion */
  .accordion { display: flex; gap: 12px; height: 460px; }
  .acc-panel {
    position: relative; flex: 1 1 0; min-width: 0;
    border-radius: 14px; overflow: hidden;
    text-decoration: none;
    transition: flex-grow 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .acc-panel:hover, .acc-panel:focus-visible, .acc-panel:focus-within { flex-grow: 3.6; outline: none; }
  .acc-panel .img {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform 0.6s ease;
  }
  .acc-panel:hover .img, .acc-panel:focus-within .img { transform: scale(1.05); }
  .acc-panel .grad {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(26,18,38,0) 30%, rgba(26,18,38,0.4) 62%, rgba(26,18,38,0.86) 100%);
  }
  .acc-panel .content { position: absolute; left: 0; right: 0; bottom: 0; padding: 22px; color: white; min-height: 122px; }
  .acc-panel .acc-bar { width: 38px; height: 5px; border-radius: 999px; background: var(--acc); margin-bottom: 12px; }
  .acc-panel h4 { font-family: var(--sans); font-weight: 700; font-size: 18px; color: white; line-height: 1.15; letter-spacing: -0.01em; }
  .acc-panel .sub { font-size: 13px; opacity: 0.85; margin-top: 3px; }
  .acc-panel .detail {
    font-size: 14px; line-height: 1.5; max-width: 340px;
    opacity: 0; max-height: 0; margin-top: 0; overflow: hidden;
    transition: opacity 0.3s ease 0.08s, max-height 0.35s ease, margin-top 0.35s ease;
  }
  .acc-panel:hover .detail, .acc-panel:focus-within .detail { opacity: 0.92; max-height: 84px; margin-top: 10px; }
  .acc-panel .explore {
    display: inline-flex; align-items: center; gap: 8px;
    font-weight: 600; font-size: 14px; color: white;
    opacity: 0; transform: translateY(6px); margin-top: 0;
    transition: opacity 0.3s ease 0.14s, transform 0.3s ease 0.14s, margin-top 0.35s ease;
  }
  .acc-panel:hover .explore, .acc-panel:focus-within .explore { opacity: 1; transform: translateY(0); margin-top: 14px; }
  .acc-panel .explore i { color: var(--acc); }

  /* mobile fallback — stack the panels (no hover on touch) */
  @media (max-width: 900px) {
    .accordion { flex-direction: column; height: auto; }
    .acc-panel { flex: none; height: 150px; }
    .acc-panel .detail, .acc-panel .explore { opacity: 1; max-height: none; margin-top: 8px; transform: none; }
  }

  /* ============================================================
     DISCOVER — combined featured tile + tabbed cards
     ============================================================ */
  .discover {
    background: var(--paper);
    position: relative;
  }
  /* let the Discover heading run full width; keep the sub-para constrained */
  .discover .section-head { max-width: none; }
  .discover .section-head .lead { max-width: 720px; }
  /* featured tile (lead editorial) */
  /* featured item — light card (no purple panel); prominence via scale + imagery */
  .feat-tile {
    background: white;
    border: 1px solid var(--line);
    color: var(--ink);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    min-height: 384px;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    margin-bottom: 48px;
    box-shadow: 0 24px 50px rgba(65,0,140,0.08);
  }
  .feat-tile .img {
    background-image: url("https://images.unsplash.com/photo-1509062522246-3755977927d7?w=900&q=80&auto=format&fit=crop");
    background-size: cover; background-position: center;
  }
  .feat-tile .body {
    padding: 52px;
    display: flex; flex-direction: column; justify-content: center;
    position: relative;
    background: linear-gradient(135deg, #ffffff 0%, var(--sand-soft) 100%);
  }
  .feat-tile .badge {
    display: inline-block;
    background: var(--sand); color: var(--ink);
    padding: 6px 14px; border-radius: 999px;
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    margin-bottom: 18px;
    align-self: flex-start;
  }
  .feat-tile h3 { font-size: 42px; line-height: 1.0; margin-bottom: 16px; color: var(--purple); max-width: 90%; }
  .feat-tile p { font-size: 17px; color: var(--charcoal); margin-bottom: 24px; line-height: 1.5; max-width: 92%; }
  .feat-tile .meta-line { font-size: 14px; color: var(--charcoal); margin-bottom: 28px; display: flex; gap: 20px; flex-wrap: wrap; }
  .feat-tile .meta-line span { display: inline-flex; align-items: center; gap: 8px; }
  .feat-tile .meta-line i { color: var(--purple); font-size: 14px; width: 14px; text-align: center; }
  .feat-tile .btn-feat {
    background: var(--purple); color: white;
    padding: 14px 28px; border-radius: 999px;
    font-weight: 700; font-size: 15px;
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 10px;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .feat-tile .btn-feat:hover { background: var(--purple-deep); transform: translateY(-2px); }
  .feat-tile .btn-feat::after { content: "→"; }

  /* tabs */
  .tabs {
    display: inline-flex; gap: 2px;
    background: white; border-radius: 999px;
    padding: 4px;
    margin: 0 auto 32px;
    width: fit-content;
    box-shadow: 0 2px 12px rgba(65,0,140,0.07);
  }
  .tabs a {
    padding: 8px 20px; border-radius: 999px;
    font-size: 14px; font-weight: 600;
    color: var(--charcoal);
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .tabs a:hover { color: var(--purple); }
  .tabs a.active { background: var(--purple); color: white; }
  .tabs a.active:hover { color: white; }

  .tabs-wrap { text-align: center; }

  /* cards — light (no purple fill); purple used for title + accents */
  .courses { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .course-card {
    background: white;
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    display: flex; flex-direction: column;
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .course-card:hover { transform: translateY(-4px); box-shadow: 0 18px 36px rgba(65,0,140,0.10); border-color: transparent; }
  .course-card .img { height: 180px; background-size: cover; background-position: center; position: relative; }
  .course-card .body { padding: 22px; flex: 1; display: flex; flex-direction: column; }
  .course-card h4 { font-family: var(--sans); font-weight: 700; font-size: 18px; line-height: 1.25; margin-bottom: 14px; color: var(--ink); letter-spacing: -0.01em; }
  .meta { font-size: 13px; color: var(--charcoal); display: grid; gap: 8px; margin-top: auto; }
  .meta .line { display: flex; align-items: center; gap: 10px; }
  .meta .line i { color: var(--purple); font-size: 13px; width: 14px; text-align: center; flex-shrink: 0; }
  /* type label hugs the top-left corner (not a pill) — per live T&E cards */
  .pill {
    position: absolute; top: 0; left: 0;
    background: white; color: var(--ink);
    padding: 9px 16px; border-radius: 0 0 12px 0;
    font-size: 12px; font-weight: 600;
  }
  .pill.right { left: auto; top: 12px; right: 12px; background: var(--sand); color: var(--ink); border-radius: 999px; padding: 5px 12px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  /* hover "Read more" lozenge, bottom-right of image */
  .course-card .img::after {
    content: "Read more"; position: absolute; right: 0; bottom: 0;
    background: #fff; color: var(--ink); font-size: 14px; font-weight: 600;
    padding: 13px 20px 13px 52px; border-radius: 14px 0 0 0;
    opacity: 0; transform: translateY(8px); transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }
  .course-card .img::before {
    content: "\f061"; font-family: "Font Awesome 6 Free"; font-weight: 900; font-size: 12px;
    position: absolute; right: 106px; bottom: 10px; width: 26px; height: 26px; border-radius: 50%;
    background: var(--purple); color: #fff; display: grid; place-items: center; z-index: 1;
    opacity: 0; transform: translateY(8px); transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }
  @media (hover: hover) {
    .course-card:hover .img::after, .course-card:hover .img::before { opacity: 1; transform: none; }
  }

  .discover-foot { margin-top: 36px; text-align: center; }

  /* ============================================================
     SUPPORTED EMPLOYMENT — standalone bar (B's treatment)
     ============================================================ */
  /* Beyond Education — light pastel ombre + circles, dark text */
  .spotlight {
    background: linear-gradient(135deg, var(--pink-soft) 0%, var(--lavender-soft) 30%, var(--cyan-soft) 70%, var(--mint-soft) 100%);
    color: var(--charcoal);
    position: relative; overflow: hidden;
  }
  .spotlight::before {
    content: ""; position: absolute;
    width: 480px; height: 480px; border-radius: 50%;
    background: var(--pink); opacity: 0.4;
    left: -160px; bottom: -160px;
  }
  .spotlight::after {
    content: ""; position: absolute;
    width: 320px; height: 320px; border-radius: 50%;
    background: var(--lavender-soft); opacity: 0.55;
    right: -100px; top: -100px;
  }
  .spotlight .container { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .spotlight .eyebrow { color: var(--purple); }
  .spotlight h2 { color: var(--purple); font-size: 52px; margin-bottom: 24px; }
  .spotlight p { font-size: 18px; color: var(--charcoal); margin-bottom: 28px; line-height: 1.6; }
  .spotlight-img {
    height: 440px;
    border-radius: 200px 30px 30px 200px;
    background-size: cover; background-position: center;
    background-image: url("https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=900&q=80&auto=format&fit=crop");
    box-shadow: 0 30px 60px rgba(65,0,140,0.18);
  }
  .spotlight .btn-light {
    background: var(--purple); color: white;
    padding: 16px 32px; border-radius: 999px;
    font-weight: 700; font-size: 15px;
    display: inline-flex; align-items: center; gap: 10px;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .spotlight .btn-light:hover { background: var(--purple-deep); transform: translateY(-2px); }
  .spotlight .btn-light::after { content: "→"; }

  /* ============================================================
     TRUST — combined stats + testimonial, light gradient
     ============================================================ */
  .trust {
    background: var(--paper);
    padding: 100px 0;
    position: relative; overflow: hidden;
  }
  .trust .container { position: relative; z-index: 2; display: grid; grid-template-columns: 1.1fr 1fr; gap: 80px; align-items: center; }
  .trust-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 40px 48px; }
