</section>

<!-- ================= CONTACT ================= -->
<section class="contact-band">
  <div class="container">
    <div class="contact-card">
      <div>
        <h3>Need advice before you book?</h3>
        <p>Our team can help you find the right course or arrange bespoke training for your setting.</p>
      </div>
      <a href="#" class="btn-primary btn-lg">Contact us <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- ================= FOOTER (shared) ================= -->

<script is:inline>
// date option selection (mock)
  document.querySelectorAll('.date-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('.date-opt').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
    });
  });
</script>

</Base>
