---
// Shared site footer (integrated newsletter + link columns).
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-cta">
      <div>
        <h3>Stay in the loop.</h3>
        <p>Practical ideas, new training and the latest from the Knowledge Hub — straight to your inbox.</p>
      </div>
      <form class="news-form" onsubmit="return false">
        <input placeholder="Enter your email address" />
        <button type="submit">Sign up <i class="fa-solid fa-arrow-right"></i></button>
      </form>
    </div>

    <div class="footer-main">
      <div class="footer-brand">
        <img src="/tep-logo.png" alt="The Education People" />
        <p>Practical training, expert consultancy and resources — supporting everyone in education, from early years through to employment beyond.</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
          <a href="#" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
          <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#" aria-label="Email"><i class="fa-solid fa-envelope"></i></a>
        </div>
      </div>
      <div class="footer-col"><h5>Our expertise</h5><ul><li><a href="#">Training &amp; Events</a></li><li><a href="#">Consultancy</a></li><li><a href="#">Knowledge Hub</a></li><li><a href="#">Products &amp; Resources</a></li><li><a href="#">Supported Employment</a></li></ul></div>
      <div class="footer-col"><h5>For members</h5><ul><li><a href="#">Register / Login</a></li><li><a href="#">My account</a></li><li><a href="#">Basket</a></li><li><a href="#">Newsletter sign-up</a></li></ul></div>
      <div class="footer-col"><h5>Get in touch</h5><ul><li>1 Abbey Wood Road,<br />Kings Hill, West Malling,<br />Kent, ME19 4YT</li><li><a href="#">Contact us</a></li></ul></div>
    </div>

    <div class="footer-bottom">
      <div>© Edseco Ltd, trading as The Education People 2026 · Company no. 10970974 · VAT 290868265</div>
      <div class="legal"><a href="#">Privacy</a><a href="#">Cookies</a><a href="#">Accessibility</a><a href="#">Anti-slavery</a></div>
    </div>
  </div>
</footer>
